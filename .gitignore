.claude/
.DS_Store

# Narration audio is hosted as GitHub Release assets (tag: audio-v1), NOT in
# this repo — 1.9 GB of MP3s would blow past the GitHub Pages size limit and
# violate the Pages "no file server" ToS. Regenerate + re-upload with
# tools/audio/sync_audio.py if articles change. See js/audio-player.js +
# audio-manifest.json for how the site references them.
# NOTE: leading slash anchors this to the repo root so it does NOT match
# tools/audio/ (the sync tooling, which IS tracked).
#
# EXCEPTION: the backend-fundamentals series IS committed (same-origin) so its
# narration plays on iOS — WebKit refuses release assets (they serve
# application/octet-stream + Content-Disposition: attachment, cross-origin).
# 16 files / ~717 MB, all < 100 MB. js/audio-player.js routes these slugs to
# /audio/<slug-path>/index.mp3 instead of the release URL.
/audio/*
!/audio/backend-fundamentals/

# Python bytecode from the audio tooling
tools/audio/__pycache__/
tools/audio/verbal_cache/
tools/audio/llm_verbal_cache/
